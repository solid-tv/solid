{
  "name": "@solidtv/solid",
  "version": "1.3.6",
  "description": "SolidTV",
  "type": "module",
  "exports": {
    ".": {
      "@solidtv/source": "./src/index.ts",
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./primitives": {
      "@solidtv/source": "./src/primitives/index.ts",
      "import": {
        "types": "./dist/src/primitives/index.d.ts",
        "default": "./dist/src/primitives/index.js"
      }
    },
    "./primitives/router": {
      "@solidtv/source": "./src/primitives/routerIndex.ts",
      "import": {
        "types": "./dist/src/primitives/routerIndex.d.ts",
        "default": "./dist/src/primitives/routerIndex.js"
      }
    },
    "./devtools": {
      "@solidtv/source": "./src/devtools/index.ts",
      "import": {
        "types": "./dist/src/devtools/index.d.ts",
        "default": "./dist/src/devtools/index.js"
      }
    },
    "./devtools/jsx-locator": "./src/devtools/jsx-locator.js",
    "./shaders": {
      "@solidtv/source": "./src/shaders/index.ts",
      "import": {
        "types": "./dist/src/shaders/index.d.ts",
        "default": "./dist/src/shaders/index.js"
      }
    },
    "./jsx-runtime": {
      "@solidtv/source": "./jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "start": "pnpm run watch",
    "test": "vitest",
    "lint": "pnpm run lint:prettier && pnpm run lint:eslint",
    "lint:fix": "pnpm run lint:fix:prettier && pnpm run lint:fix:eslint",
    "lint:prettier": "prettier --check \"**/*.{ts,js,cjs,md}\"",
    "lint:fix:prettier": "prettier --write \"**/*.{ts,js,cjs,md}\"",
    "lint:eslint": "eslint .",
    "lint:fix:eslint": "eslint --fix .",
    "build": "rm -rf dist && pnpm run tsc && cp jsx-runtime.d.ts dist/",
    "tsc": "tsc",
    "watch": "tsc -w",
    "prepare": "husky",
    "prepack": "pnpm run build",
    "release": "release-it",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "keywords": [
    "lightning",
    "javascript",
    "canvas",
    "web",
    "tv"
  ],
  "author": "Chris Lorenzo",
  "license": "Apache-2.0",
  "dependencies": {
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/list": "^0.1.2",
    "@solid-primitives/mouse": "^2.1.6",
    "@solid-primitives/scheduled": "^1.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@solid-devtools/debugger": "^0.28.1",
    "@solidjs/testing-library": "^0.8.10",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/browser-playwright": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.13",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,cjs,md}": "prettier --write"
  },
  "peerDependencies": {
    "@solidjs/router": "^0.16.1",
    "@solidtv/renderer": "^1.5.4",
    "solid-js": "*"
  },
  "peerDependenciesMeta": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solid-tv/solid.git"
  },
  "files": [
    "dist",
    "src",
    "jsx-runtime.d.ts",
    "LICENSE",
    "NOTICE",
    "README.md",
    "docs/AI_CODING_GUIDELINES.md"
  ],
  "packageManager": "pnpm@10.33.4",
  "publishConfig": {
    "access": "public"
  }
}
